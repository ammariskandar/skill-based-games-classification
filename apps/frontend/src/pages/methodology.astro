---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;
---

<BaseLayout title="Methodology — Skill-Based Games Classification">
  <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Methodology</h1>
  <p class="mt-4 text-lg text-neutral-600">
    Each game receives two independent profiles — Challenge and Reward — each
    scored across Micro, Mystiko, and Macro. Together they describe skill
    composition, not difficulty or quality.
  </p>
</BaseLayout>
