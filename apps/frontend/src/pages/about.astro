---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;
---

<BaseLayout title="About — Skill-Based Games Classification">
  <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">About</h1>
  <p class="mt-4 text-lg text-neutral-600">
    Skill-Based Games Classification is a web application that classifies games
    across three skill-based dimensions — Micro, Mystiko, and Macro — within
    separate Challenge and Reward profiles.
  </p>
</BaseLayout>
