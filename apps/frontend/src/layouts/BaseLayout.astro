---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const title = Astro.props.title ?? "Skill-Based Games Classification";
const description =
  Astro.props.description ??
  "Classifying games through the lens of skill, using Micro, Mystiko, and Macro dimensions within separate Challenge and Reward profiles.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen">
    <main class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
      <slot />
    </main>
  </body>
</html>
