{
  "name": "skill-based-games-classification",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:backend": "source apps/backend/.venv/bin/activate && python apps/backend/manage.py runserver",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "test:frontend": "echo 'test:frontend — not yet implemented'",
    "test:backend": "echo 'test:backend — not yet implemented'",
    "test": "echo 'test — not yet implemented; run test:frontend and test:backend separately'",
    "lint": "echo 'lint — not yet implemented'",
    "format": "echo 'format — not yet implemented'",
    "migrate": "source apps/backend/.venv/bin/activate && python apps/backend/manage.py migrate",
    "install:backend": "python3 -m venv apps/backend/.venv && apps/backend/.venv/bin/python -m pip install -r apps/backend/requirements.txt"
  }
}
